<svg width="800" height="500" viewBox="0 0 800 500" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="500" fill="#05131f"/>
  <rect x="15" y="15" width="770" height="470" rx="12" fill="#081f33" stroke="#3FE03E" stroke-opacity="0.2" stroke-width="2"/>
  
  <!-- Glowing laptop mockup -->
  <rect x="250" y="100" width="300" height="180" rx="10" fill="#0c2c47" stroke="#3FE03E" stroke-opacity="0.4" stroke-width="3"/>
  <rect x="260" y="110" width="280" height="150" rx="6" fill="#05131f"/>
  
  <!-- Code lines inside laptop -->
  <rect x="275" y="125" width="120" height="8" rx="4" fill="#3FE03E"/>
  <rect x="275" y="140" width="180" height="8" rx="4" fill="#133c5c"/>
  <rect x="290" y="155" width="140" height="8" rx="4" fill="#31C030"/>
  <rect x="290" y="170" width="100" height="8" rx="4" fill="#133c5c"/>
  <rect x="305" y="185" width="160" height="8" rx="4" fill="#3FE03E" fill-opacity="0.8"/>
  <rect x="275" y="200" width="150" height="8" rx="4" fill="#133c5c"/>
  <rect x="275" y="215" width="80" height="8" rx="4" fill="#ef4444" fill-opacity="0.6"/>

  <!-- Laptop base -->
  <polygon points="210,280 590,280 610,300 190,300" fill="#0c2c47" stroke="#3FE03E" stroke-opacity="0.4" stroke-width="2"/>
  <rect x="360" y="280" width="80" height="6" rx="3" fill="#133c5c"/>

  <!-- Coffee mug -->
  <rect x="150" y="220" width="30" height="50" rx="6" fill="#133c5c"/>
  <path d="M 135,230 C 125,230 125,250 135,250" stroke="#133c5c" stroke-width="4" fill="none"/>
  
  <!-- Plant pot -->
  <polygon points="620,220 660,220 650,270 630,270" fill="#31C030" fill-opacity="0.3"/>
  <path d="M 640,220 Q 620,180 600,200 Q 640,160 640,220" stroke="#3FE03E" stroke-width="4" fill="none"/>
  <path d="M 640,220 Q 660,180 680,200 Q 640,160 640,220" stroke="#3FE03E" stroke-width="4" fill="none"/>

  <!-- Workspace title -->
  <text x="400" y="360" text-anchor="middle" fill="#ffffff" font-family="sans-serif" font-size="24" font-weight="black">ESCRITORIO DE DESARROLLO (DEVELOPER SETUP)</text>
  <text x="400" y="395" text-anchor="middle" fill="#3FE03E" font-family="monospace" font-size="14" font-weight="bold">LFCC://WORK_SESSION_ACTIVE</text>
  <text x="400" y="425" text-anchor="middle" fill="#a0aec0" font-family="sans-serif" font-size="13">Donde las ideas se traducen en líneas de código y arquitecturas robustas.</text>
</svg>
