<svg width="800" height="600" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#071926"/>
  <rect x="20" y="20" width="760" height="560" rx="12" fill="#0c253a" stroke="#3FE03E" stroke-opacity="0.3" stroke-width="2"/>
  
  <!-- Header Bar -->
  <rect x="40" y="40" width="720" height="50" rx="6" fill="#071926"/>
  <circle cx="60" cy="65" r="6" fill="#ef4444"/>
  <circle cx="80" cy="65" r="6" fill="#eab308"/>
  <circle cx="100" cy="65" r="6" fill="#22c55e"/>
  <text x="130" y="70" fill="#3FE03E" font-family="monospace" font-size="14" font-weight="bold">LFCC_SALES_ENGINE://v1.0.0</text>
  <rect x="580" y="50" width="160" height="30" rx="4" fill="#133c5c"/>
  <text x="595" y="69" fill="#ffffff" font-family="sans-serif" font-size="12">Admin Luis F.</text>

  <!-- Sales charts grid -->
  <!-- Main Chart Card -->
  <rect x="40" y="110" width="460" height="280" rx="8" fill="#071926" stroke="#3FE03E" stroke-opacity="0.1"/>
  <text x="60" y="140" fill="#ffffff" font-family="sans-serif" font-size="16" font-weight="bold">Ventas Mensuales (Monthly Sales)</text>
  
  <!-- Bars -->
  <rect x="80" y="220" width="30" height="130" rx="4" fill="#133c5c"/>
  <rect x="130" y="180" width="30" height="170" rx="4" fill="#133c5c"/>
  <rect x="180" y="260" width="30" height="90" rx="4" fill="#133c5c"/>
  <rect x="230" y="150" width="30" height="200" rx="4" fill="#3FE03E"/>
  <rect x="280" y="190" width="30" height="160" rx="4" fill="#133c5c"/>
  <rect x="330" y="240" width="30" height="110" rx="4" fill="#133c5c"/>
  <rect x="380" y="110" width="30" height="240" rx="4" fill="#3FE03E"/>
  <rect x="430" y="210" width="30" height="140" rx="4" fill="#133c5c"/>

  <!-- Side Metrics Card -->
  <rect x="520" y="110" width="240" height="280" rx="8" fill="#071926" stroke="#3FE03E" stroke-opacity="0.1"/>
  <text x="540" y="145" fill="#a0aec0" font-family="sans-serif" font-size="14">Ingresos Totales</text>
  <text x="540" y="180" fill="#3FE03E" font-family="sans-serif" font-size="28" font-weight="bold">$124,530 USD</text>
  
  <text x="540" y="235" fill="#a0aec0" font-family="sans-serif" font-size="14">Margen de Ganancia</text>
  <text x="540" y="270" fill="#ffffff" font-family="sans-serif" font-size="24" font-weight="bold">68.4%</text>

  <rect x="540" y="300" width="200" height="8" rx="4" fill="#133c5c"/>
  <rect x="540" y="300" width="136" height="8" rx="4" fill="#3FE03E"/>

  <text x="540" y="340" fill="#31C030" font-family="sans-serif" font-size="12" font-weight="bold">▲ +12.4% este mes</text>

  <!-- Table Card at Bottom -->
  <rect x="40" y="410" width="720" height="150" rx="8" fill="#071926" stroke="#3FE03E" stroke-opacity="0.1"/>
  <text x="60" y="440" fill="#ffffff" font-family="sans-serif" font-size="14" font-weight="bold">Transacciones Recientes</text>
  
  <line x1="60" y1="460" x2="740" y2="460" stroke="#133c5c" stroke-width="1"/>
  
  <!-- Table rows -->
  <text x="60" y="485" fill="#a0aec0" font-family="sans-serif" font-size="12">ID 10594</text>
  <text x="200" y="485" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold">Suscripción SaaS Pro</text>
  <text x="450" y="485" fill="#3FE03E" font-family="sans-serif" font-size="12" font-weight="bold">Completado</text>
  <text x="680" y="485" fill="#ffffff" font-family="sans-serif" font-size="12">$349.00</text>

  <line x1="60" y1="505" x2="740" y2="505" stroke="#133c5c" stroke-opacity="0.5" stroke-width="1"/>

  <text x="60" y="530" fill="#a0aec0" font-family="sans-serif" font-size="12">ID 10593</text>
  <text x="200" y="530" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold">Licencia de Base de Datos</text>
  <text x="450" y="530" fill="#3FE03E" font-family="sans-serif" font-size="12" font-weight="bold">Completado</text>
  <text x="680" y="530" fill="#ffffff" font-family="sans-serif" font-size="12">$1,200.00</text>
</svg>
