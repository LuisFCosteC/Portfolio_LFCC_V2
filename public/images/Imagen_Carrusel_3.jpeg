<svg width="800" height="500" viewBox="0 0 800 500" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="500" fill="#05131f"/>
  <rect x="15" y="15" width="770" height="470" rx="12" fill="#081f33" stroke="#3FE03E" stroke-opacity="0.2" stroke-width="2"/>

  <!-- Agile Board / Burndown visual representation -->
  <!-- Board columns mock-up -->
  <rect x="100" y="80" width="180" height="180" rx="8" fill="#05131f" stroke="#133c5c"/>
  <rect x="110" y="110" width="160" height="40" rx="4" fill="#31C030" fill-opacity="0.2"/>
  <rect x="110" y="160" width="160" height="40" rx="4" fill="#3FE03E" fill-opacity="0.1"/>
  <rect x="110" y="210" width="160" height="40" rx="4" fill="#133c5c" fill-opacity="0.5"/>

  <!-- Burndown Chart representation -->
  <rect x="340" y="80" width="360" height="180" rx="8" fill="#05131f" stroke="#133c5c"/>
  <text x="360" y="110" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold">Progreso del Sprint (Burn Down)</text>
  
  <!-- Grid lines -->
  <line x1="360" y1="130" x2="680" y2="130" stroke="#133c5c" stroke-opacity="0.3"/>
  <line x1="360" y1="170" x2="680" y2="170" stroke="#133c5c" stroke-opacity="0.3"/>
  <line x1="360" y1="210" x2="680" y2="210" stroke="#133c5c" stroke-opacity="0.3"/>
  
  <!-- Line graphs -->
  <!-- Target line -->
  <line x1="360" y1="120" x2="680" y2="230" stroke="#a0aec0" stroke-width="2" stroke-dasharray="5,5"/>
  <!-- Actual line -->
  <path d="M 360,120 L 420,130 L 480,150 L 540,185 L 600,210 L 680,230" stroke="#3FE03E" stroke-width="3" stroke-linecap="round"/>

  <!-- Texts -->
  <text x="400" y="360" text-anchor="middle" fill="#ffffff" font-family="sans-serif" font-size="24" font-weight="black">METODOLOGÍAS ÁGILES (AGILE PROCESS)</text>
  <text x="400" y="395" text-anchor="middle" fill="#3FE03E" font-family="monospace" font-size="14" font-weight="bold">SCRUM_ALLIANCE://DAILY_STANDUP</text>
  <text x="400" y="425" text-anchor="middle" fill="#a0aec0" font-family="sans-serif" font-size="13">Gestión de proyectos estructurada y centrada en entregas de valor continuo.</text>
</svg>
