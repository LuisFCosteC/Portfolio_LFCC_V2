<svg width="800" height="500" viewBox="0 0 800 500" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="500" fill="#05131f"/>
  <rect x="15" y="15" width="770" height="470" rx="12" fill="#081f33" stroke="#3FE03E" stroke-opacity="0.2" stroke-width="2"/>

  <!-- Code layout window mockup -->
  <rect x="100" y="80" width="600" height="200" rx="10" fill="#05131f" stroke="#3FE03E" stroke-opacity="0.2"/>
  
  <!-- Window top bar buttons -->
  <circle cx="125" cy="100" r="6" fill="#ef4444"/>
  <circle cx="145" cy="100" r="6" fill="#eab308"/>
  <circle cx="165" cy="100" r="6" fill="#22c55e"/>

  <!-- Code text lines (simulating elegant typography) -->
  <text x="120" y="140" fill="#3FE03E" font-family="monospace" font-size="14" font-weight="bold">const</text>
  <text x="170" y="140" fill="#ffffff" font-family="monospace" font-size="14">portfolio</text>
  <text x="250" y="140" fill="#31C030" font-family="monospace" font-size="14">=</text>
  <text x="270" y="140" fill="#3FE03E" font-family="monospace" font-size="14">async</text>
  <text x="320" y="140" fill="#133c5c" font-family="monospace" font-size="14">() => {</text>

  <text x="150" y="165" fill="#3FE03E" font-family="monospace" font-size="14">await</text>
  <text x="200" y="165" fill="#ffffff" font-family="monospace" font-size="14">buildDreams({</text>
  <text x="310" y="165" fill="#a0aec0" font-family="monospace" font-size="14">quality: 'pristine'</text>
  <text x="460" y="165" fill="#ffffff" font-family="monospace" font-size="14">});</text>

  <text x="150" y="190" fill="#a0aec0" font-family="monospace" font-size="14">// Clean code rules applied daily</text>

  <text x="150" y="215" fill="#3FE03E" font-family="monospace" font-size="14">return</text>
  <text x="210" y="215" fill="#ffffff" font-family="monospace" font-size="14">new</text>
  <text x="245" y="215" fill="#31C030" font-family="monospace" font-size="14">Success</text>
  <text x="300" y="215" fill="#133c5c" font-family="monospace" font-size="14">();</text>

  <text x="120" y="240" fill="#133c5c" font-family="monospace" font-size="14">};</text>

  <!-- Texts -->
  <text x="400" y="360" text-anchor="middle" fill="#ffffff" font-family="sans-serif" font-size="24" font-weight="black">CÓDIGO LIMPIO (CLEAN CODE INTEGRATION)</text>
  <text x="400" y="395" text-anchor="middle" fill="#3FE03E" font-family="monospace" font-size="14" font-weight="bold">SOLID_PRINCIPLES://REFACTOR_PASS</text>
  <text x="400" y="425" text-anchor="middle" fill="#a0aec0" font-family="sans-serif" font-size="13">Aplicación de patrones de diseño, legibilidad de código y testing automatizado.</text>
</svg>
