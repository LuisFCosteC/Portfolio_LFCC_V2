<svg width="800" height="600" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#071926"/>
  <rect x="20" y="20" width="760" height="560" rx="12" fill="#0c253a" stroke="#3FE03E" stroke-opacity="0.3" stroke-width="2"/>

  <!-- Left Navigation Rail -->
  <rect x="40" y="40" width="60" height="520" rx="8" fill="#071926" stroke="#133c5c"/>
  <circle cx="70" cy="80" r="15" fill="#3FE03E"/>
  <!-- Icons in left rail as circles/rects -->
  <rect x="55" y="140" width="30" height="30" rx="6" fill="#133c5c"/>
  <rect x="55" y="190" width="30" height="30" rx="6" fill="#0c253a" stroke="#133c5c"/>
  <rect x="55" y="240" width="30" height="30" rx="6" fill="#0c253a" stroke="#133c5c"/>
  <rect x="55" y="290" width="30" height="30" rx="6" fill="#0c253a" stroke="#133c5c"/>

  <!-- Main Patient statistics and EMR panel -->
  <!-- Top Row Metrics -->
  <rect x="120" y="40" width="200" height="100" rx="8" fill="#071926" stroke="#3FE03E" stroke-opacity="0.1"/>
  <text x="140" y="70" fill="#a0aec0" font-family="sans-serif" font-size="13">Pacientes Atendidos</text>
  <text x="140" y="110" fill="#ffffff" font-family="sans-serif" font-size="28" font-weight="bold">1,482</text>

  <rect x="340" y="40" width="200" height="100" rx="8" fill="#071926" stroke="#3FE03E" stroke-opacity="0.1"/>
  <text x="360" y="70" fill="#a0aec0" font-family="sans-serif" font-size="13">Citas de Hoy</text>
  <text x="360" y="110" fill="#3FE03E" font-family="sans-serif" font-size="28" font-weight="bold">24</text>

  <rect x="560" y="40" width="200" height="100" rx="8" fill="#071926" stroke="#3FE03E" stroke-opacity="0.1"/>
  <text x="580" y="70" fill="#a0aec0" font-family="sans-serif" font-size="13">Ocupación Quirófano</text>
  <text x="580" y="110" fill="#ffffff" font-family="sans-serif" font-size="28" font-weight="bold">84%</text>

  <!-- ECG Pulse wave form graphics -->
  <rect x="120" y="160" width="640" height="180" rx="8" fill="#071926" stroke="#3FE03E" stroke-opacity="0.1"/>
  <text x="140" y="195" fill="#ffffff" font-family="sans-serif" font-size="16" font-weight="bold">Frecuencia Cardíaca Promedio (ECG Live Link)</text>
  <text x="640" y="195" fill="#3FE03E" font-family="monospace" font-size="14" font-weight="bold">72 BPM</text>

  <!-- Pulse Wave Path -->
  <path d="M 140,270 L 220,270 L 230,250 L 240,290 L 250,230 L 260,310 L 270,270 L 380,270 L 390,250 L 400,290 L 410,230 L 420,310 L 430,270 L 550,270 L 560,250 L 570,290 L 580,230 L 590,310 L 600,270 L 720,270" stroke="#3FE03E" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>

  <!-- Patient List Card -->
  <rect x="120" y="360" width="640" height="200" rx="8" fill="#071926" stroke="#3FE03E" stroke-opacity="0.1"/>
  <text x="140" y="395" fill="#ffffff" font-family="sans-serif" font-size="14" font-weight="bold">Agenda de Pacientes del Día</text>
  
  <line x1="140" y1="415" x2="720" y2="415" stroke="#133c5c" stroke-width="1"/>
  
  <!-- Rows -->
  <text x="140" y="440" fill="#a0aec0" font-family="sans-serif" font-size="12">08:00 AM</text>
  <text x="240" y="440" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold">Dra. María Restrepo - Cardiología</text>
  <text x="500" y="440" fill="#ffffff" font-family="sans-serif" font-size="12">Paciente: Jorge Echeverry</text>
  <rect x="660" y="425" width="60" height="20" rx="4" fill="#3FE03E" fill-opacity="0.2"/>
  <text x="670" y="439" fill="#3FE03E" font-family="sans-serif" font-size="10" font-weight="bold">Listo</text>

  <line x1="140" y1="460" x2="720" y2="460" stroke="#133c5c" stroke-opacity="0.5" stroke-width="1"/>

  <text x="140" y="485" fill="#a0aec0" font-family="sans-serif" font-size="12">09:15 AM</text>
  <text x="240" y="485" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold">Dr. Carlos Sierra - Pediatría</text>
  <text x="500" y="485" fill="#ffffff" font-family="sans-serif" font-size="12">Paciente: Sofía Gómez (Control)</text>
  <rect x="660" y="470" width="60" height="20" rx="4" fill="#ef4444" fill-opacity="0.2"/>
  <text x="670" y="484" fill="#ef4444" font-family="sans-serif" font-size="10" font-weight="bold">Espera</text>

  <line x1="140" y1="505" x2="720" y2="505" stroke="#133c5c" stroke-opacity="0.5" stroke-width="1"/>

  <text x="140" y="530" fill="#a0aec0" font-family="sans-serif" font-size="12">10:30 AM</text>
  <text x="240" y="530" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold">Dra. Clara Bermúdez - Nutrición</text>
  <text x="500" y="530" fill="#ffffff" font-family="sans-serif" font-size="12">Paciente: Andrés Ospina</text>
  <rect x="660" y="515" width="60" height="20" rx="4" fill="#eab308" fill-opacity="0.2"/>
  <text x="670" y="529" fill="#eab308" font-family="sans-serif" font-size="10" font-weight="bold">Próximo</text>
</svg>
