<svg width="800" height="600" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#071926"/>
  <rect x="20" y="20" width="760" height="560" rx="12" fill="#0c253a" stroke="#3FE03E" stroke-opacity="0.3" stroke-width="2"/>

  <!-- Left: Mobile phone mockup -->
  <rect x="80" y="50" width="260" height="500" rx="30" fill="#071926" stroke="#133c5c" stroke-width="4"/>
  <!-- Phone Notch/Speaker -->
  <rect x="160" y="60" width="100" height="15" rx="7" fill="#133c5c"/>
  
  <!-- Map display in phone -->
  <rect x="95" y="90" width="230" height="320" rx="12" fill="#1b2e3f"/>
  
  <!-- Map Roads lines -->
  <line x1="95" y1="200" x2="325" y2="200" stroke="#071926" stroke-width="6"/>
  <line x1="95" y1="280" x2="325" y2="300" stroke="#071926" stroke-width="6"/>
  <line x1="180" y1="90" x2="180" y2="410" stroke="#071926" stroke-width="6"/>
  <line x1="260" y1="90" x2="260" y2="410" stroke="#071926" stroke-width="6"/>

  <!-- Delivery route -->
  <path d="M 180,350 L 180,285 L 260,290" stroke="#3FE03E" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  
  <!-- Courier pin -->
  <circle cx="260" cy="290" r="10" fill="#3FE03E"/>
  <circle cx="260" cy="290" r="4" fill="#071926"/>

  <!-- Client pin -->
  <circle cx="180" cy="350" r="8" fill="#ef4444"/>
  
  <!-- Bottom info card inside phone -->
  <rect x="95" y="425" width="230" height="105" rx="12" fill="#0c253a" stroke="#3FE03E" stroke-opacity="0.2"/>
  <text x="110" y="450" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold">Tu pedido está en camino</text>
  <text x="110" y="468" fill="#a0aec0" font-family="sans-serif" font-size="10">Tiempo estimado: 12 min</text>
  
  <!-- Progress bar -->
  <rect x="110" y="482" width="200" height="6" rx="3" fill="#071926"/>
  <rect x="110" y="482" width="140" height="6" rx="3" fill="#3FE03E"/>

  <text x="110" y="508" fill="#3FE03E" font-family="sans-serif" font-size="11" font-weight="bold">Repartidor: Carlos Gómez</text>

  <!-- Right: Large Desktop details panel -->
  <rect x="380" y="50" width="370" height="500" rx="12" fill="#071926" stroke="#3FE03E" stroke-opacity="0.1"/>
  <text x="410" y="95" fill="#ffffff" font-family="sans-serif" font-size="22" font-weight="bold">App Domicilios GPS</text>
  <text x="410" y="125" fill="#3FE03E" font-family="sans-serif" font-size="14" font-weight="bold">Panel de Monitoreo Admin</text>
  
  <!-- Analytics statistics -->
  <rect x="410" y="160" width="310" height="70" rx="8" fill="#0c253a" stroke="#133c5c"/>
  <text x="430" y="190" fill="#a0aec0" font-family="sans-serif" font-size="12">Pedidos Activos</text>
  <text x="430" y="215" fill="#ffffff" font-family="sans-serif" font-size="20" font-weight="bold">482</text>
  <text x="620" y="215" fill="#3FE03E" font-family="sans-serif" font-size="12" font-weight="bold">▲ +18% h/h</text>

  <rect x="410" y="245" width="310" height="70" rx="8" fill="#0c253a" stroke="#133c5c"/>
  <text x="430" y="275" fill="#a0aec0" font-family="sans-serif" font-size="12">Tiempo Promedio</text>
  <text x="430" y="300" fill="#3FE03E" font-family="sans-serif" font-size="20" font-weight="bold">24.5 min</text>
  <text x="640" y="300" fill="#ef4444" font-family="sans-serif" font-size="12" font-weight="bold">▼ -3.2%</text>

  <!-- Map live log console -->
  <rect x="410" y="330" width="310" height="190" rx="8" fill="#0c253a" stroke="#3FE03E" stroke-opacity="0.1"/>
  <text x="425" y="360" fill="#3FE03E" font-family="monospace" font-size="11" font-weight="bold">> LOGS_ACTIVIDAD_MÓVIL:</text>
  <text x="425" y="385" fill="#ffffff" font-family="monospace" font-size="10">14:23:01 [MÓVIL] Repartidor #12 conectado</text>
  <text x="425" y="405" fill="#ffffff" font-family="monospace" font-size="10">14:23:10 [GPS] Coord_Actualiz: 4.609,-74.081</text>
  <text x="425" y="425" fill="#3FE03E" font-family="monospace" font-size="10">14:23:15 [APP] Pedido #5942 despachado</text>
  <text x="425" y="445" fill="#ffffff" font-family="monospace" font-size="10">14:23:22 [DB] Firebase Sync completado</text>
  <text x="425" y="465" fill="#ffffff" font-family="monospace" font-size="10">14:23:24 [NOTIF] Cliente #8243 alertado</text>
</svg>
