<svg width="800" height="600" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#071926"/>
  <rect x="20" y="20" width="760" height="560" rx="12" fill="#0c253a" stroke="#3FE03E" stroke-opacity="0.3" stroke-width="2"/>

  <!-- Kanban Header -->
  <rect x="40" y="40" width="720" height="50" rx="6" fill="#071926"/>
  <text x="60" y="72" fill="#ffffff" font-family="sans-serif" font-size="18" font-weight="bold">Tablero Scrum: Sprint #14</text>
  <rect x="620" y="50" width="120" height="30" rx="4" fill="#3FE03E" fill-opacity="0.2" stroke="#3FE03E" stroke-opacity="0.3"/>
  <text x="635" y="69" fill="#3FE03E" font-family="sans-serif" font-size="12" font-weight="bold">+ Nueva Tarea</text>

  <!-- Kanban Columns -->
  <!-- Col 1: TO DO (Por Hacer) -->
  <rect x="40" y="110" width="220" height="450" rx="8" fill="#071926" stroke="#133c5c"/>
  <text x="55" y="140" fill="#a0aec0" font-family="sans-serif" font-size="14" font-weight="bold">POR HACER (3)</text>
  <line x1="55" y1="155" x2="245" y2="155" stroke="#133c5c" stroke-width="2"/>
  
  <!-- Task Card 1 -->
  <rect x="50" y="170" width="200" height="100" rx="6" fill="#0c253a" stroke="#133c5c"/>
  <text x="60" y="195" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold">Integrar API de Mapas</text>
  <text x="60" y="215" fill="#a0aec0" font-family="sans-serif" font-size="10">Configurar SDK de mapas en la app</text>
  <rect x="60" y="235" width="45" height="18" rx="4" fill="#ef4444" fill-opacity="0.2"/>
  <text x="67" y="247" fill="#ef4444" font-family="sans-serif" font-size="8" font-weight="bold">Alta</text>
  <text x="210" y="248" fill="#a0aec0" font-family="sans-serif" font-size="10">8h</text>

  <!-- Task Card 2 -->
  <rect x="50" y="280" width="200" height="100" rx="6" fill="#0c253a" stroke="#133c5c"/>
  <text x="60" y="305" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold">Pruebas Unitarias de Auth</text>
  <text x="60" y="325" fill="#a0aec0" font-family="sans-serif" font-size="10">Validar login y registros con Mock</text>
  <rect x="60" y="345" width="45" height="18" rx="4" fill="#eab308" fill-opacity="0.2"/>
  <text x="67" y="357" fill="#eab308" font-family="sans-serif" font-size="8" font-weight="bold">Media</text>
  <text x="210" y="358" fill="#a0aec0" font-family="sans-serif" font-size="10">5h</text>

  <!-- Col 2: IN PROGRESS (En Proceso) -->
  <rect x="290" y="110" width="220" height="450" rx="8" fill="#071926" stroke="#3FE03E" stroke-opacity="0.2"/>
  <text x="305" y="140" fill="#3FE03E" font-family="sans-serif" font-size="14" font-weight="bold">EN PROCESO (2)</text>
  <line x1="305" y1="155" x2="495" y2="155" stroke="#3FE03E" stroke-opacity="0.3" stroke-width="2"/>

  <!-- Task Card 3 -->
  <rect x="300" y="170" width="200" height="100" rx="6" fill="#0c253a" stroke="#3FE03E" stroke-opacity="0.3"/>
  <text x="310" y="195" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold">Refactorizar Redux Store</text>
  <text x="310" y="215" fill="#a0aec0" font-family="sans-serif" font-size="10">Migrar a slices de Redux Toolkit</text>
  <rect x="310" y="235" width="45" height="18" rx="4" fill="#ef4444" fill-opacity="0.2"/>
  <text x="317" y="247" fill="#ef4444" font-family="sans-serif" font-size="8" font-weight="bold">Alta</text>
  <text x="460" y="248" fill="#3FE03E" font-family="sans-serif" font-size="10" font-weight="bold">13h</text>

  <!-- Col 3: DONE (Completado) -->
  <rect x="540" y="110" width="220" height="450" rx="8" fill="#071926" stroke="#133c5c"/>
  <text x="555" y="140" fill="#22c55e" font-family="sans-serif" font-size="14" font-weight="bold">HECHO (5)</text>
  <line x1="555" y1="155" x2="745" y2="155" stroke="#22c55e" stroke-opacity="0.3" stroke-width="2"/>

  <!-- Task Card 4 -->
  <rect x="550" y="170" width="200" height="100" rx="6" fill="#0c253a" stroke="#133c5c" opacity="0.6"/>
  <text x="560" y="195" fill="#ffffff" font-family="sans-serif" font-size="12" font-weight="bold" style="text-decoration: line-through;">Diseño de Base de Datos</text>
  <text x="560" y="215" fill="#a0aec0" font-family="sans-serif" font-size="10" style="text-decoration: line-through;">Esquema SQL e Índices iniciales</text>
  <rect x="560" y="235" width="45" height="18" rx="4" fill="#22c55e" fill-opacity="0.2"/>
  <text x="567" y="247" fill="#22c55e" font-family="sans-serif" font-size="8" font-weight="bold">Baja</text>
  <text x="710" y="248" fill="#a0aec0" font-family="sans-serif" font-size="10">21h</text>
</svg>
